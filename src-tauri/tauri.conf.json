{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "BlackHole",
  "version": "0.1.0",
  "identifier": "com.blackhole.remind",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "blackhole",
        "title": "BlackHole",
        "width": 800,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false
      },
      {
        "label": "settings",
        "title": "BlackHole Settings",
        "url": "index.html#settings",
        "width": 400,
        "height": 600,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": true,
        "resizable": false,
        "center": true
      },
      {
        "label": "preview",
        "title": "BlackHole Preview",
        "width": 120,
        "height": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
